# ============================================================
# StoryMagic Environment Variables
# Copy to .env.local and fill in values for local development
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/storymagic
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/storymagic
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=

# --- AI Providers: Text Generation ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=sk-...

# --- AI Providers: Image Generation ---
COMFYUI_API_URL=http://localhost:8188
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# --- AI Providers: Voice ---
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
FISH_AUDIO_API_KEY=

# --- AI Providers: Face Processing ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Encryption ---
AWS_KMS_KEY_ID=
AWS_REGION=eu-west-1
ENCRYPTION_MASTER_KEY=dev-master-key-change-in-production

# --- Print Providers ---
LULU_API_KEY=
LULU_API_SECRET=
LULU_SANDBOX=true

# --- Monitoring ---
SENTRY_DSN=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=storymagic-dev

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=storymagic
TEMPORAL_TASK_QUEUE=book-generation

# --- Application ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NODE_ENV=development

# --- Email (dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@storymagic.dev
